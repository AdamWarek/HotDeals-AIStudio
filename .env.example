# Optional — Proxy for Puppeteer scrapers (e.g. Hebe). Urban Outfitters scraper is currently disabled in scrape.js.
# Format: http://user:pass@host:port  or  socks5://host:port
# SCRAPER_PROXY_URL=

# Optional: Gmail API for `npm run ingest-newsletters` (see Google Cloud Console → Gmail API → OAuth client).
# Writes public/data/nike_promos.json & adidas_promos.json when mail is found. Scrape does NOT merge them unless:
# MERGE_NEWSLETTER_DEALS=1
#
# Step 3 — refresh token (one-time): put CLIENT_ID + CLIENT_SECRET below, leave REFRESH_TOKEN empty, then run:
#   npm run gmail-oauth-setup
# Add redirect URI in Google Cloud → Credentials → your OAuth client:
#   http://127.0.0.1:34567/oauth2callback
# (If you only have a "Desktop" client and get redirect_uri_mismatch, create an additional "Web application"
# client with that redirect URI, or add the URI if the console allows it on your client type.)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Set to 1 so `npm run scrape` appends newsletter JSON into deals.json (default: off locally).
# GitHub Actions daily scraper sets MERGE_NEWSLETTER_DEALS=1 after ingest-newsletters.
# MERGE_NEWSLETTER_DEALS=1

# Optional Gmail search queries. Defaults target forwards from pusto@poczta.fm to wiruje2@gmail.com
# (From header is poczta.fm; body keywords match Nike/Adidas marketing).
# You can instead use a label, e.g. NEWSLETTER_QUERY_NIKE=label:ForwardedPromos newer_than:30d (nike OR lego)
# NEWSLETTER_QUERY_NIKE=from:pusto@poczta.fm newer_than:30d (nike OR lego OR "em.nike" OR "nike.com")
# NEWSLETTER_QUERY_ADIDAS=from:pusto@poczta.fm newer_than:30d (adidas OR adiclub OR "link.adidas" OR "adidas.com")
# NEWSLETTER_MAX_MESSAGES=12
# NEWSLETTER_INGEST_SKIP=1

# --- Firebase (web) ---
# Local: set all VITE_FIREBASE_* below (see Firebase Console → Project settings → Your apps).
# Production CI: omit VITE_FIREBASE_API_KEY; set VITE_FIREBASE_PROJECT_ID + VITE_FIREBASE_FIRESTORE_DATABASE_ID
# so the app loads config from https://<PROJECT_ID>.firebaseapp.com/__/firebase/init.json (no apiKey in static JS).
# Optional: VITE_FIREBASE_INIT_JSON_URL=... to override that URL (e.g. https://<project>.web.app/__/firebase/init.json).
# Deploy Firebase Hosting at least once (see firebase.json → firebase-hosting-stub) so init.json exists.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_FIRESTORE_DATABASE_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
