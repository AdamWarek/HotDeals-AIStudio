# Optional: Gmail API for `npm run ingest-newsletters` (see Google Cloud Console → Gmail API → OAuth client).
# If unset, ingest exits 0 and scrape.js only merges existing public/data/nike_promos.json & adidas_promos.json.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Optional Gmail search queries (defaults are sensible for PL marketing mail)
# NEWSLETTER_QUERY_NIKE=newer_than:30d (from:nike OR from:@nike.com)
# NEWSLETTER_QUERY_ADIDAS=newer_than:30d (from:adidas OR from:@adidas.com OR from:@adidas.pl)
# NEWSLETTER_MAX_MESSAGES=12
# NEWSLETTER_INGEST_SKIP=1
