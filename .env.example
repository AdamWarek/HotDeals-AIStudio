# Optional — Proxy for Puppeteer scrapers (Hebe, Urban Outfitters).
# Format: http://user:pass@host:port  or  socks5://host:port
# SCRAPER_PROXY_URL=

# Optional: Gmail API for `npm run ingest-newsletters` (see Google Cloud Console → Gmail API → OAuth client).
# Writes public/data/nike_promos.json & adidas_promos.json when mail is found. Scrape does NOT merge them unless:
# MERGE_NEWSLETTER_DEALS=1
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Set to 1 so `npm run scrape` appends newsletter JSON into deals.json (default: off — scrapers only).
# MERGE_NEWSLETTER_DEALS=1

# Optional Gmail search queries. Defaults target forwards from pusto@poczta.fm to wiruje2@gmail.com
# (From header is poczta.fm; body keywords match Nike/Adidas marketing).
# You can instead use a label, e.g. NEWSLETTER_QUERY_NIKE=label:ForwardedPromos newer_than:30d (nike OR lego)
# NEWSLETTER_QUERY_NIKE=from:pusto@poczta.fm newer_than:30d (nike OR lego OR "em.nike" OR "nike.com")
# NEWSLETTER_QUERY_ADIDAS=from:pusto@poczta.fm newer_than:30d (adidas OR adiclub OR "link.adidas" OR "adidas.com")
# NEWSLETTER_MAX_MESSAGES=12
# NEWSLETTER_INGEST_SKIP=1
