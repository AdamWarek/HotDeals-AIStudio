# Firebase Web SDK — from Firebase Console → Project settings → Your apps (Web).
# Copy this file to .env and fill in values. Never commit .env.
# For GitHub Pages CI, add the same variables as repository Secrets (names must match).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Named Firestore database ID (not "(default)" unless you use default).
VITE_FIREBASE_FIRESTORE_DATABASE_ID=
# Optional; leave empty if unused
VITE_FIREBASE_MEASUREMENT_ID=
