{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "email"]
    },
    "Deal": {
      "title": "Deal",
      "description": "A deal posted on the platform",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "currentPrice": { "type": "number" },
        "originalPrice": { "type": "number" },
        "imageUrl": { "type": "string" },
        "temperature": { "type": "integer" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "category": { "type": "string" }
      },
      "required": ["title", "currentPrice", "imageUrl", "temperature", "authorUid", "createdAt"]
    },
    "Vote": {
      "title": "Vote",
      "description": "A vote on a deal",
      "type": "object",
      "properties": {
        "dealId": { "type": "string" },
        "userUid": { "type": "string" },
        "value": { "type": "integer", "enum": [1, -1] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["dealId", "userUid", "value", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "/deals/{dealId}": {
      "schema": "Deal",
      "description": "Collection of deals"
    },
    "/deals/{dealId}/votes/{voteId}": {
      "schema": "Vote",
      "description": "Subcollection of votes for a specific deal"
    }
  }
}
